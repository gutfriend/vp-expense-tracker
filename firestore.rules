rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Accounts collection
    match /accounts/{accountId} {
      allow read, write: if true;  // Lock this down once you add auth
    }

    // Transactions collection
    match /transactions/{txnId} {
      allow read, write: if true;  // Lock this down once you add auth
    }
  }
}
